            <tr><td><strong>Running Total</strong></td><td class="code">SUM(amount) OVER (ORDER BY date ROWS UNBOUNDED PRECEDING)</td><td class="desc">Cumulative revenue over time</td></tr>
            <tr><td><strong>Period-over-Period</strong></td><td class="code">LAG(revenue, 1) OVER (ORDER BY month)</td><td class="desc">Compare this month vs last month</td></tr>
            <tr><td><strong>Percentile Bucket</strong></td><td class="code">NTILE(4) OVER (ORDER BY score)</td><td class="desc">Quartile segmentation of customers</td></tr>
            <tr><td><strong>Dedup Rows</strong></td><td class="code">SELECT * FROM (SELECT *, ROW_NUMBER() OVER (PARTITION BY id ORDER BY updated_at DESC) rn FROM t) WHERE rn=1</td><td class="desc">Keep latest record per ID</td></tr>
            <tr><td><strong>Pivot (CASE)</strong></td><td class="code">SUM(CASE WHEN status='active' THEN 1 ELSE 0 END) AS active_count</td><td class="desc">Pivot row values to columns</td></tr>
            <tr><td><strong>Recursive CTE</strong></td><td class="code">WITH RECURSIVE cte AS (SELECT ... UNION ALL SELECT ... FROM cte WHERE ...)</td><td class="desc">Org hierarchy, date sequences</td></tr>
            <tr><td><strong>Date Truncation</strong></td><td class="code">DATE_TRUNC('month', created_at)</td><td class="desc">Group by month/week/year</td></tr>
            <tr><td><strong>Moving Average</strong></td><td class="code">AVG(revenue) OVER (ORDER BY date ROWS 6 PRECEDING)</td><td class="desc">7-day rolling average</td></tr>
            <tr><td><strong>Cohort Month</strong></td><td class="code">DATE_TRUNC('month', MIN(created_at) OVER (PARTITION BY user_id))</td><td class="desc">User's cohort acquisition month</td></tr>
            <tr><td><strong>JSON Extract</strong></td><td class="code">JSON_EXTRACT(data, '$.key') or data->>'key'</td><td class="desc">Read semi-structured data</td></tr>
            <tr><td><strong>String Split</strong></td><td class="code">SPLIT_PART(email, '@', 2)</td><td class="desc">Extract domain from email</td></tr>
          </tbody>
        </table>
      </div>

