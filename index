<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data Analyst Mastery — SQL & Python Roadmap</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --bg2: #111118;
    --bg3: #16161f;
    --surface: #1c1c28;
    --surface2: #242433;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #f0f0f5;
    --text2: #9494aa;
    --text3: #5a5a72;
    --accent: #7c6af7;
    --accent2: #a855f7;
    --gold: #f59e0b;
    --teal: #14b8a6;
    --coral: #f97316;
    --green: #22c55e;
    --red: #ef4444;
    --blue: #3b82f6;
    --pink: #ec4899;
    --sql: #f59e0b;
    --py: #3b82f6;
    --r: 12px;
    --r2: 8px;
    --shadow: 0 8px 40px rgba(0,0,0,0.4);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    position: fixed; left:0; top:0; width:260px; height:100vh;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    z-index: 100; overflow-y: auto;
  }
  .sidebar-logo {
    padding: 24px 20px 16px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-logo .brand {
    font-size: 13px; color: var(--text3); text-transform: uppercase;
    letter-spacing: 2px; margin-bottom: 6px;
  }
  .sidebar-logo h1 {
    font-size: 18px; font-weight: 800; line-height: 1.2;
    background: linear-gradient(135deg, var(--accent), var(--pink));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .progress-ring-wrap {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }
  .progress-mini {
    display: flex; align-items: center; gap: 12px;
  }
  .ring-svg { transform: rotate(-90deg); }
  .ring-track { fill: none; stroke: var(--surface2); stroke-width: 4; }
  .ring-fill { fill: none; stroke: var(--accent); stroke-width: 4;
    stroke-dasharray: 100; stroke-linecap: round;
    transition: stroke-dashoffset 0.6s ease; }
  .ring-info { flex: 1; }
  .ring-pct { font-size: 22px; font-weight: 800; color: var(--text); }
  .ring-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; }
  .nav-section { padding: 8px 0; }
  .nav-group-label {
    font-size: 10px; color: var(--text3); text-transform: uppercase;
    letter-spacing: 2px; padding: 12px 20px 4px;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 20px; cursor: pointer; transition: all 0.15s;
    font-size: 13px; color: var(--text2); position: relative;
    border-left: 3px solid transparent;
  }
  .nav-item:hover { background: var(--surface); color: var(--text); }
  .nav-item.active { color: var(--accent); background: rgba(124,106,247,0.08);
    border-left-color: var(--accent); }
  .nav-dot { width: 8px; height: 8px; border-radius: 50%;
    background: var(--surface2); flex-shrink: 0; transition: all 0.2s; }
  .nav-item.active .nav-dot { background: var(--accent); box-shadow: 0 0 8px var(--accent); }
  .nav-badge {
    margin-left: auto; font-size: 10px;
    background: var(--surface2); border-radius: 99px;
    padding: 2px 7px; color: var(--text3);
  }
  .nav-item.active .nav-badge { background: rgba(124,106,247,0.2); color: var(--accent); }
  .streak-bar {
    margin: auto 20px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r2);
    padding: 12px;
  }
  .streak-label { font-size: 11px; color: var(--text3); text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 8px; }
  .streak-days { display: flex; gap: 4px; }
  .day-dot { width: 18px; height: 18px; border-radius: 4px;
    background: var(--surface2); cursor: pointer; transition: all 0.2s; }
  .day-dot.done { background: var(--accent); }
  .day-dot.today { background: var(--gold); }

  /* ── MAIN ── */
  .main { margin-left: 260px; min-height: 100vh; }
  .topbar {
    position: sticky; top: 0; z-index: 50;
    background: rgba(10,10,15,0.9); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    height: 60px; display: flex; align-items: center; gap: 16px;
  }
  .topbar-title { font-size: 15px; font-weight: 700; color: var(--text); }
  .topbar-subtitle { font-size: 13px; color: var(--text3); }
  .topbar-actions { margin-left: auto; display: flex; gap: 8px; }
  .btn { padding: 7px 14px; border-radius: var(--r2); font-size: 12px;
    font-weight: 600; cursor: pointer; transition: all 0.15s; border: none;
    font-family: 'Syne', sans-serif; }
  .btn-ghost { background: transparent; border: 1px solid var(--border2); color: var(--text2); }
  .btn-ghost:hover { background: var(--surface); color: var(--text); }
  .btn-accent { background: var(--accent); color: white; }
  .btn-accent:hover { background: #6c5ae0; }

  /* ── CONTENT PAGES ── */
  .page { display: none; padding: 32px; max-width: 1100px; }
  .page.active { display: block; }

  /* ── CARDS ── */
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 20px 24px; margin-bottom: 16px;
  }
  .card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .card-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .card-title { font-size: 15px; font-weight: 700; }
  .card-subtitle { font-size: 12px; color: var(--text3); margin-top: 2px; }

  /* ── STAT GRID ── */
  .stat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 28px; }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 20px;
  }
  .stat-val { font-size: 28px; font-weight: 800; }
  .stat-lbl { font-size: 11px; color: var(--text3); text-transform: uppercase;
    letter-spacing: 1px; margin-top: 4px; }
  .stat-sub { font-size: 12px; color: var(--text2); margin-top: 6px; }

  /* ── TOPIC ROW ── */
  .topic-row {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; border-radius: var(--r2);
    border: 1px solid var(--border); margin-bottom: 8px;
    background: var(--bg3); cursor: pointer; transition: all 0.15s;
    position: relative; overflow: hidden;
  }
  .topic-row:hover { border-color: var(--border2); background: var(--surface); }
  .topic-row.done { border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.04); }
  .topic-row.done::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--green);
  }
  .topic-check {
    width: 22px; height: 22px; border-radius: 6px;
    border: 1.5px solid var(--border2); display: flex;
    align-items: center; justify-content: center;
    flex-shrink: 0; transition: all 0.2s; font-size: 12px;
  }
  .topic-row.done .topic-check { background: var(--green); border-color: var(--green); color: white; }
  .topic-name { flex: 1; font-size: 14px; font-weight: 500; }
  .topic-row.done .topic-name { text-decoration: line-through; color: var(--text3); }
  .topic-tags { display: flex; gap: 6px; }
  .tag {
    font-size: 10px; padding: 3px 8px; border-radius: 99px;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .tag-beg { background: rgba(34,197,94,0.15); color: #4ade80; }
  .tag-int { background: rgba(245,158,11,0.15); color: #fbbf24; }
  .tag-adv { background: rgba(239,68,68,0.15); color: #f87171; }
  .tag-sql { background: rgba(245,158,11,0.12); color: var(--sql); }
  .tag-py { background: rgba(59,130,246,0.12); color: var(--py); }
  .tag-must { background: rgba(236,72,153,0.15); color: #f472b6; border: 1px solid rgba(236,72,153,0.3); }

  /* ── SECTION HEADER ── */
  .section-hdr {
    display: flex; align-items: center; gap: 12px;
    margin: 28px 0 16px;
  }
  .section-hdr h2 { font-size: 18px; font-weight: 800; }
  .section-hdr-line { flex: 1; height: 1px; background: var(--border); }
  .section-progress { font-size: 12px; color: var(--text3); }

  /* ── ACCORDION ── */
  .acc-header {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; cursor: pointer;
    border-radius: var(--r2); background: var(--surface2);
    border: 1px solid var(--border); margin-bottom: 2px;
    transition: all 0.15s;
  }
  .acc-header:hover { border-color: var(--border2); }
  .acc-header.open { border-color: var(--accent); background: rgba(124,106,247,0.06); }
  .acc-title { flex: 1; font-size: 14px; font-weight: 600; }
  .acc-arrow { transition: transform 0.2s; font-size: 12px; color: var(--text3); }
  .acc-header.open .acc-arrow { transform: rotate(180deg); }
  .acc-body { display: none; padding: 16px 18px;
    background: var(--bg3); border: 1px solid var(--border);
    border-top: none; border-radius: 0 0 var(--r2) var(--r2);
    margin-bottom: 8px; }
  .acc-body.open { display: block; }

  /* ── CODE BLOCK ── */
  .code-block {
    background: #0d0d14; border: 1px solid var(--border);
    border-radius: var(--r2); padding: 16px 20px;
    font-family: 'DM Mono', monospace; font-size: 13px;
    color: #e2e8f0; overflow-x: auto; margin: 12px 0;
    position: relative;
  }
  .code-block .kw { color: #a78bfa; }
  .code-block .fn { color: #60a5fa; }
  .code-block .str { color: #34d399; }
  .code-block .cm { color: #6b7280; font-style: italic; }
  .code-block .num { color: #fbbf24; }
  .code-block .op { color: #f472b6; }
  .copy-btn {
    position: absolute; top: 10px; right: 10px;
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text3); padding: 4px 10px; border-radius: 6px;
    font-size: 11px; cursor: pointer; transition: all 0.15s;
    font-family: 'Syne', sans-serif;
  }
  .copy-btn:hover { color: var(--text); background: var(--surface); }

  /* ── 90-DAY PLAN ── */
  .plan-phase {
    border: 1px solid var(--border); border-radius: var(--r);
    margin-bottom: 16px; overflow: hidden;
  }
  .plan-phase-hdr {
    padding: 16px 20px; display: flex; align-items: center; gap: 14px;
    cursor: pointer;
  }
  .phase-num {
    width: 42px; height: 42px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 800; flex-shrink: 0;
  }
  .plan-phase-body { padding: 0 20px 20px; display: none; }
  .plan-phase-body.open { display: block; }
  .week-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 12px; }
  .week-card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--r2); padding: 14px;
  }
  .week-lbl { font-size: 11px; color: var(--text3); text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 8px; }
  .week-items li { font-size: 13px; color: var(--text2); margin-bottom: 5px;
    list-style: none; padding-left: 16px; position: relative; }
  .week-items li::before { content: '→'; position: absolute; left: 0;
    color: var(--accent); font-size: 11px; }

  /* ── FORMULA TABLE ── */
  .formula-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .formula-table th {
    text-align: left; padding: 10px 14px;
    background: var(--surface2); color: var(--text3);
    font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
    border-bottom: 1px solid var(--border);
  }
  .formula-table td {
    padding: 11px 14px; border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .formula-table tr:hover td { background: var(--surface); }
  .formula-table .code { font-family: 'DM Mono', monospace;
    font-size: 12px; color: var(--teal); }
  .formula-table .desc { color: var(--text2); }
  .formula-table .example { color: var(--text3); font-style: italic; }

  /* ── PROJECT CARDS ── */
  .project-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 22px 24px; margin-bottom: 16px;
    position: relative; overflow: hidden;
  }
  .project-card::after {
    content: ''; position: absolute; top: 0; right: 0;
    width: 120px; height: 120px; border-radius: 50%;
    opacity: 0.04; transform: translate(40px, -40px);
  }
  .project-meta { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
  .project-title { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .project-desc { font-size: 13px; color: var(--text2); line-height: 1.7; margin-bottom: 14px; }
  .project-section { margin-bottom: 12px; }
  .project-section-lbl { font-size: 11px; color: var(--text3); text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 6px; }
  .project-section-val { font-size: 13px; color: var(--text2); }
  .dataset-chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--r2); padding: 5px 10px;
    font-size: 12px; color: var(--text2); cursor: pointer;
    text-decoration: none; transition: all 0.15s;
  }
  .dataset-chip:hover { border-color: var(--accent); color: var(--accent); }
  .difficulty-bar {
    display: flex; gap: 3px; margin-top: 8px;
  }
  .diff-dot { width: 20px; height: 4px; border-radius: 2px; background: var(--surface2); }
  .diff-dot.filled { background: var(--accent); }

  /* ── INTERVIEW ── */
  .iq-card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--r2); margin-bottom: 10px; overflow: hidden;
  }
  .iq-q {
    padding: 14px 18px; cursor: pointer; font-size: 13px;
    font-weight: 600; display: flex; align-items: center; gap: 10px;
    transition: background 0.15s;
  }
  .iq-q:hover { background: var(--surface); }
  .iq-num { width: 24px; height: 24px; border-radius: 6px;
    background: var(--surface2); display: flex; align-items: center;
    justify-content: center; font-size: 11px; color: var(--text3);
    flex-shrink: 0; font-family: 'DM Mono', monospace; }
  .iq-a { display: none; padding: 14px 18px; border-top: 1px solid var(--border);
    font-size: 13px; color: var(--text2); line-height: 1.8;
    background: var(--bg2); }
  .iq-a.open { display: block; }

  /* ── SHORTCUTS ── */
  .shortcuts-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .shortcut-item {
    display: flex; align-items: center; gap: 10px;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--r2); padding: 10px 14px;
  }
  .kbd {
    font-family: 'DM Mono', monospace; font-size: 11px;
    background: var(--surface2); border: 1px solid var(--border2);
    border-radius: 5px; padding: 3px 8px; color: var(--text);
    white-space: nowrap; flex-shrink: 0;
  }
  .shortcut-desc { font-size: 12px; color: var(--text2); }

  /* ── SCENARIOS ── */
  .scenario-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 20px 22px; margin-bottom: 14px;
  }
  .scenario-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
  .scenario-context { font-size: 12px; color: var(--text3); margin-bottom: 12px; }
  .scenario-steps li { font-size: 13px; color: var(--text2); margin-bottom: 6px;
    line-height: 1.6; }

  /* ── BEST PRACTICES ── */
  .bp-item {
    display: flex; gap: 14px; padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .bp-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
  .bp-title { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
  .bp-text { font-size: 13px; color: var(--text2); line-height: 1.6; }

  /* ── TABS ── */
  .tabs { display: flex; gap: 4px; margin-bottom: 20px;
    border-bottom: 1px solid var(--border); padding-bottom: 0; }
  .tab-btn {
    padding: 8px 16px; font-size: 13px; font-weight: 600;
    cursor: pointer; border: none; background: transparent;
    color: var(--text3); border-bottom: 2px solid transparent;
    transition: all 0.15s; font-family: 'Syne', sans-serif;
    margin-bottom: -1px;
  }
  .tab-btn:hover { color: var(--text); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ── HEADER HERO ── */
  .hero {
    padding: 40px 32px 0;
    background: radial-gradient(ellipse at 70% 0, rgba(124,106,247,0.12) 0%, transparent 60%);
  }
  .hero-eyebrow { font-size: 11px; color: var(--accent); text-transform: uppercase;
    letter-spacing: 3px; margin-bottom: 10px; }
  .hero-title { font-size: 38px; font-weight: 800; line-height: 1.1; margin-bottom: 12px; }
  .hero-title span { background: linear-gradient(135deg, var(--accent), var(--pink));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-sub { font-size: 15px; color: var(--text2); max-width: 600px; line-height: 1.7;
    margin-bottom: 28px; }
  .hero-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
  .hero-chip {
    padding: 6px 14px; border-radius: 99px; font-size: 12px; font-weight: 600;
    border: 1px solid; display: flex; align-items: center; gap: 6px;
  }

  /* ── MUST KNOW BANNER ── */
  .must-know-banner {
    background: linear-gradient(135deg, rgba(236,72,153,0.08), rgba(124,106,247,0.08));
    border: 1px solid rgba(236,72,153,0.2); border-radius: var(--r);
    padding: 16px 20px; margin-bottom: 20px;
    display: flex; align-items: flex-start; gap: 12px;
  }
  .must-know-banner .icon { font-size: 22px; margin-top: 1px; }
  .must-know-banner h3 { font-size: 14px; font-weight: 700; margin-bottom: 6px; color: #f472b6; }
  .must-know-banner p { font-size: 13px; color: var(--text2); line-height: 1.6; }

  /* ── DASHBOARD CHARTS ── */
  .mini-chart { height: 40px; display: flex; align-items: flex-end; gap: 3px; }
  .mini-bar { flex: 1; border-radius: 3px 3px 0 0;
    background: var(--accent); opacity: 0.6; min-height: 4px; }
  .mini-bar:hover { opacity: 1; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text3); }

  /* ── NOTIFICATION ── */
  .toast {
    position: fixed; bottom: 24px; right: 24px; z-index: 999;
    background: var(--surface2); border: 1px solid var(--border2);
    border-radius: var(--r2); padding: 12px 18px;
    font-size: 13px; color: var(--text);
    transform: translateY(80px); opacity: 0;
    transition: all 0.3s; pointer-events: none;
  }
  .toast.show { transform: translateY(0); opacity: 1; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .sidebar { width: 220px; }
    .main { margin-left: 220px; }
    .stat-grid { grid-template-columns: repeat(2,1fr); }
  }

  /* ── PILLS COLORS ── */
  .pill-sql { background: rgba(245,158,11,0.1); color: var(--sql); border: 1px solid rgba(245,158,11,0.2); }
  .pill-py { background: rgba(59,130,246,0.1); color: var(--py); border: 1px solid rgba(59,130,246,0.2); }
  .pill-both { background: rgba(124,106,247,0.1); color: var(--accent); border: 1px solid rgba(124,106,247,0.2); }
  .pill-adv { background: rgba(239,68,68,0.1); color: var(--red); border: 1px solid rgba(239,68,68,0.2); }
  .pill-int { background: rgba(245,158,11,0.1); color: var(--gold); border: 1px solid rgba(245,158,11,0.2); }
  .pill-beg { background: rgba(34,197,94,0.1); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }

  .highlight { color: var(--accent); font-weight: 600; }
  .text-green { color: var(--green); }
  .text-gold { color: var(--gold); }
  .text-blue { color: var(--blue); }
  .text-pink { color: var(--pink); }
  .text-teal { color: var(--teal); }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="brand">Analyst Mastery</div>
    <h1>SQL & Python<br>Roadmap</h1>
