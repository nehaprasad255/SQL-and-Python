          <thead><tr><th>Operation</th><th>Code</th><th>Use Case</th></tr></thead>
          <tbody>
            <tr><td><strong>GroupBy + Agg</strong></td><td class="code">df.groupby('dept').agg({'sal':['mean','sum','count']})</td><td class="desc">Multi-metric aggregation</td></tr>
            <tr><td><strong>Pivot Table</strong></td><td class="code">df.pivot_table(values='sales', index='region', columns='product', aggfunc='sum', fill_value=0)</td><td class="desc">Cross-tabulation report</td></tr>
            <tr><td><strong>Merge (JOIN)</strong></td><td class="code">pd.merge(df1, df2, on='user_id', how='left')</td><td class="desc">SQL LEFT JOIN equivalent</td></tr>
