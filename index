    { q: 'What is a correlated subquery? Give a real example.', a: 'A correlated subquery references a column from the outer query, re-executing for each outer row. Example: "Find employees earning more than their department average" — SELECT name FROM employees e WHERE salary > (SELECT AVG(salary) FROM employees WHERE dept = e.dept). Can be slow; often replaceable with window functions.' },
    { q: 'How do you calculate month-over-month revenue change?', a: 'Use LAG(): SELECT month, revenue, LAG(revenue,1) OVER (ORDER BY month) AS prev_month, revenue - LAG(revenue,1) OVER (ORDER BY month) AS mom_change, ROUND(100.0*(revenue - LAG(revenue,1) OVER (ORDER BY month))/LAG(revenue,1) OVER (ORDER BY month), 2) AS pct_change FROM monthly_revenue.' },
    { q: 'What is the difference between INNER JOIN and LEFT JOIN?', a: 'INNER JOIN returns only rows where a match exists in both tables. LEFT JOIN returns all rows from the left table, with NULLs for right-table columns where no match exists. Use LEFT JOIN when you want to keep all records from the primary entity (e.g., all users, even those with no orders).' },
    { q: 'How would you identify the top N records per group?', a: 'Use ROW_NUMBER() in a subquery or CTE: WITH ranked AS (SELECT *, ROW_NUMBER() OVER (PARTITION BY group_col ORDER BY metric DESC) AS rn FROM table) SELECT * FROM ranked WHERE rn <= N. This is a classic interview pattern — know it cold.' },
    { q: 'Explain the difference between UNION and UNION ALL.', a: 'UNION removes duplicate rows (does a distinct sort internally — slower). UNION ALL keeps all rows including duplicates (faster). Use UNION ALL by default for combining datasets where you know there are no duplicates or you want duplicates.' },
    { q: 'How would you write a cohort retention query?', a: 'Step 1: Find each user\'s first order month (cohort). Step 2: For each subsequent month, count which cohort users returned. CTE pattern: cohorts CTE gets MIN(order_month) per user → join back to orders → calculate months_since_first → pivot with CASE WHEN.' },
    { q: 'When would you use a CTE vs a subquery vs a temp table?', a: 'CTE: readable, reusable within one query, not materialized (in most DBs). Subquery: simple one-time use. Temp table: when you need to reference the result multiple times in a session, or when the intermediate result is expensive to recompute. In analytics, CTEs win for maintainability.' },
  ],
  py: [
    { q: 'What is the difference between .loc and .iloc?', a: '.loc uses label-based indexing (row labels/index values and column names). .iloc uses integer position-based indexing (0-based positions). Example: df.loc[0, "name"] accesses row with index label 0, column "name". df.iloc[0, 0] accesses the first row, first column by position.' },
    { q: 'How do you handle missing values in pandas?', a: 'First identify: df.isnull().sum() shows counts per column. Then decide strategy: dropna() if random missingness and < 5% of rows; fillna(value) with mean/median for numeric, mode for categorical; ffill()/bfill() for time series; or flag with a separate is_missing binary column. Document your choice.' },
    { q: 'What is the difference between merge() and concat()?', a: 'merge() is SQL-JOIN equivalent — combines DataFrames horizontally based on shared key columns (on=, left_on=, right_on=). concat() stacks DataFrames vertically (axis=0) or horizontally (axis=1) by position, not by key. Use merge for relational joining, concat for appending rows or columns.' },
    { q: 'Why should you avoid iterrows() in pandas?', a: 'iterrows() iterates row-by-row in Python (slow — O(n) Python loop). Vectorized operations use NumPy\'s C-level operations on entire arrays at once — often 10-1000x faster. Replace with: df["col"] operations for simple math, apply() for complex row logic, np.where() for conditionals.' },
    { q: 'How would you find the top 5 customers by revenue per region?', a: 'df.groupby(["region","customer_id"])["revenue"].sum().reset_index().sort_values("revenue", ascending=False).groupby("region").head(5). Or use rank(): df["rank"] = df.groupby("region")["revenue"].rank(method="dense", ascending=False); df[df["rank"] <= 5].' },
    { q: 'Explain groupby().transform() vs groupby().agg()', a: 'agg() collapses the group to one row per group (like SQL GROUP BY). transform() returns a Series with the same index as the original DataFrame — great for adding a group-level stat back to each row (e.g., df["dept_avg"] = df.groupby("dept")["salary"].transform("mean")). Use transform when you need both the row detail AND the group aggregate.' },
    { q: 'How do you detect and handle outliers in Python?', a: 'Z-score method: (df["col"] - df["col"].mean()) / df["col"].std() — flag rows where |z| > 3. IQR method: Q1 = df["col"].quantile(0.25); Q3 = 0.75; IQR = Q3-Q1; outliers outside [Q1 - 1.5*IQR, Q3 + 1.5*IQR]. Then: cap (clip to bounds), remove, or flag as a binary column depending on context.' },
    { q: 'What is pandas apply() and when should you use it?', a: 'apply() calls a function on each row (axis=1) or column (axis=0). Use when the operation is too complex for vectorized expressions but you need flexibility. Always check if a vectorized alternative exists first. apply() is much faster than iterrows but slower than native pandas/numpy operations.' },
  ],
  biz: [
    { q: 'DAU dropped 10% yesterday. How do you investigate?', a: 'Step 1: Verify the data is real (check pipeline health, reporting tool caching). Step 2: Segment by platform (iOS/Android/Web) — is it all platforms or one? Step 3: Segment by geography, user cohort, new vs returning. Step 4: Check if an event happened (deploy, outage, marketing campaign ended). Step 5: Look at the full funnel — did signups drop or did activation drop? Step 6: Communicate findings with confidence intervals, not just raw numbers.' },
    { q: 'How would you define and measure product-market fit?', a: 'Common proxies: Retention curves that flatten (not going to zero — users are staying). Survey-based: Sean Ellis test (>40% say "very disappointed" if product disappeared). NPS > 50. DAU/MAU ratio > 20% indicates habit formation. For analysts, build a retention curve by cohort — if it stabilizes above 0 at month 3, you have engagement. PMF is not binary.' },
    { q: 'What metrics would you track for an e-commerce business?', a: 'Acquisition: CAC, traffic by channel, conversion rate. Engagement: Sessions per user, time on site, pages per session. Monetization: GMV, AOV, revenue per user. Retention: Day-1/7/30 retention, churn rate, repeat purchase rate. Satisfaction: NPS, return rate, support ticket rate. Choose metrics that are leading indicators of revenue — not vanity metrics.' },
    { q: 'Explain the difference between correlation and causation in an analysis context.', a: 'Correlation: two variables move together (ice cream sales and drowning rates). Causation: one variable causes the other. In analysis, always ask: could a third variable explain both? (hot weather causes both). To establish causation: randomized controlled experiments (A/B tests), difference-in-differences, or instrumental variables. Always flag correlational findings as "associated with" not "causes."' },
    { q: 'How would you set up an A/B test for a new checkout flow?', a: '1) Define primary metric (checkout completion rate) and guardrail metrics (revenue per session). 2) Calculate sample size needed for statistical power (typically 80%) at significance (p < 0.05). 3) Randomize users (not sessions) — same user should see same variant. 4) Run until statistical significance, not until "it looks good." 5) Analyze by segment too (mobile vs desktop). 6) Check for novelty effect if variant involves UI changes.' },
    { q: 'What is customer cohort analysis and why is it important?', a: 'Cohort analysis groups users who share a common characteristic (usually acquisition month) and tracks their behavior over time. Importance: aggregate metrics lie (mixing old retained users with new churned users creates misleading averages). Cohort analysis shows if product quality is improving or deteriorating for new cohorts, which channels bring better long-term users, and when users typically churn.' },
  ],
  behav: [
    { q: 'Tell me about a time you found an error in someone else\'s analysis.', a: 'Use STAR method: Situation (context of the analysis/project), Task (your role), Action (how you identified the error — what did you check? how did you approach the person?), Result (what changed, what you learned). Key: show that you communicated diplomatically, focused on the data not the person, and used it as a learning moment. Mention what systematic check you implemented to prevent recurrence.' },
    { q: 'Describe a time you had to present complex analysis to a non-technical audience.', a: 'Structure: what was the business question (not the methodology), what you found (lead with the insight, not the process), what they should do (recommendation). Avoid p-values with executives — translate to "we\'re 95% confident" or "19 times out of 20." Use analogies. Show the chart first, explain the takeaway, then offer to go deeper. Demonstrate that simplification is a skill, not dumbing down.' },
    { q: 'Tell me about a time you had to work with messy or incomplete data.', a: 'Highlight: how you assessed the data quality (what checks did you run?), the judgment calls you made (imputation vs exclusion vs flagging), how you communicated data limitations in your findings (crucial — analysts who hide caveats lose trust), and what the output was despite the imperfection. Shows maturity: good analysts ship insights with documented caveats, not perfect analyses never.' },
    { q: 'How do you prioritize when you have multiple competing analysis requests?', a: 'Framework: Business impact × Urgency / Effort. Clarify with stakeholders — "urgent" often means "when you get to it." Break large requests into what\'s needed for a decision vs. nice-to-have. Use a shared tracker. Communicate ETA proactively. If priorities conflict: escalate to manager with your recommendation, don\'t just pick one unilaterally.' },
  ],
};

// ══════════════════════════════
// STATE & PERSISTENCE
// ══════════════════════════════
let checked = JSON.parse(localStorage.getItem('da_roadmap_checked') || '{}');
let streakDays = JSON.parse(localStorage.getItem('da_streak') || '[]');

function saveChecked() { localStorage.setItem('da_roadmap_checked', JSON.stringify(checked)); }
function saveStreak() { localStorage.setItem('da_streak', JSON.stringify(streakDays)); }

// ══════════════════════════════
// RENDER TOPICS
// ══════════════════════════════
function renderTopics(pageKey, containerId, sectionKey) {
  const container = document.getElementById(containerId);
  if (!container) return;
  const topics = TOPICS[sectionKey] || [];
  let html = '';
  topics.forEach((t, i) => {
    const id = `${sectionKey}_${i}`;
    const done = checked[id] ? 'done' : '';
    html += `<div class="topic-row ${done}" id="row-${id}" onclick="toggleTopic('${id}', '${sectionKey}')">
      <div class="topic-check">${checked[id] ? '✓' : ''}</div>
      <div class="topic-name">${t.name}</div>
      <div class="topic-tags">
        ${t.must ? '<span class="tag tag-must">★ Must Know</span>' : ''}
        <span class="tag tag-${t.level}">${t.level === 'beg' ? 'Beginner' : t.level === 'int' ? 'Intermediate' : 'Advanced'}</span>
        <span class="tag tag-${t.type}">${t.type === 'sql' ? 'SQL' : 'Python'}</span>
      </div>
    </div>`;
  });
  container.innerHTML = html;
}

function toggleTopic(id, sectionKey) {
  checked[id] = !checked[id];
  saveChecked();
  const row = document.getElementById(`row-${id}`);
  const check = row.querySelector('.topic-check');
  if (checked[id]) {
    row.classList.add('done');
    check.textContent = '✓';
    updateStreak();
  } else {
    row.classList.remove('done');
    check.textContent = '';
  }
  updateProgress();
}

// ══════════════════════════════
// PROGRESS CALCULATION
// ══════════════════════════════
function calcSectionProgress(sectionKey) {
  const topics = TOPICS[sectionKey] || [];
  if (!topics.length) return { done: 0, total: 0, pct: 0 };
  let done = 0;
  topics.forEach((_, i) => { if (checked[`${sectionKey}_${i}`]) done++; });
  return { done, total: topics.length, pct: Math.round(100 * done / topics.length) };
}

function updateProgress() {
  const sections = {
    sql: ['sql-basics', 'sql-int', 'sql-adv'],
    py: ['py-basics', 'py-pandas', 'py-viz', 'py-stats'],
  };
  let totalDone = 0, totalAll = 0, sqlDone = 0, sqlAll = 0, pyDone = 0, pyAll = 0;

  Object.entries(TOPICS).forEach(([key, arr]) => {
    arr.forEach((_, i) => { if (checked[`${key}_${i}`]) totalDone++; });
    totalAll += arr.length;
  });
  sections.sql.forEach(k => { const p = calcSectionProgress(k); sqlDone += p.done; sqlAll += p.total; });
  sections.py.forEach(k => { const p = calcSectionProgress(k); pyDone += p.done; pyAll += p.total; });

  const pct = totalAll ? Math.round(100 * totalDone / totalAll) : 0;
  const sqlPct = sqlAll ? Math.round(100 * sqlDone / sqlAll) : 0;
  const pyPct = pyAll ? Math.round(100 * pyDone / pyAll) : 0;

  // Ring
  const ring = document.getElementById('ring-fill');
  const circ = 2 * Math.PI * 21;
  if (ring) {
    ring.style.strokeDasharray = circ;
    ring.style.strokeDashoffset = circ * (1 - pct / 100);
  }
  setEl('ring-pct', pct + '%');
  setEl('done-count', totalDone);
  setEl('total-count', totalAll);

  // Stats
  setEl('stat-pct', pct + '%');
  setEl('stat-done', totalDone + ' topics');
  setEl('stat-sql', sqlPct + '%');
  setEl('stat-py', pyPct + '%');

  // Bars
  setBar('bar-sql-basics', calcSectionProgress('sql-basics').pct);
  setBar('bar-sql-int', calcSectionProgress('sql-int').pct);
  setBar('bar-sql-adv', calcSectionProgress('sql-adv').pct);
  setBar('bar-py-basics', calcSectionProgress('py-basics').pct);
  setBar('bar-py-pandas', calcSectionProgress('py-pandas').pct);
  setBar('bar-py-viz', calcSectionProgress('py-viz').pct);

  // Nav badges
  const nb = (key, id) => { const p = calcSectionProgress(key); setEl(id, p.pct + '%'); };
  nb('sql-basics','nb-sql-basics'); nb('sql-int','nb-sql-int'); nb('sql-adv','nb-sql-adv');
  nb('py-basics','nb-py-basics'); nb('py-pandas','nb-py-pandas'); nb('py-viz','nb-py-viz');

  // Section progress labels
  Object.entries({'sql-basics':'sp-sql-basics','sql-int':'sp-sql-int','sql-adv':'sp-sql-adv',
    'py-basics':'sp-py-basics','py-pandas':'sp-py-pandas','py-viz':'sp-py-viz'}).forEach(([k, id]) => {
    const p = calcSectionProgress(k);
    setEl(id, `${p.done} / ${p.total}`);
  });

  // Streak count
  setEl('stat-streak', streakDays.length);
}

function setEl(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
function setBar(id, pct) { const el = document.getElementById(id); if (el) el.style.width = pct + '%'; }

// ══════════════════════════════
// STREAK
// ══════════════════════════════
function updateStreak() {
  const today = new Date().toDateString();
  if (!streakDays.includes(today)) { streakDays.push(today); saveStreak(); }
}

function renderStreak() {
  const container = document.getElementById('streak-days');
  if (!container) return;
  let html = '';
  for (let i = 6; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const ds = d.toDateString();
    const isToday = i === 0;
    const done = streakDays.includes(ds);
    html += `<div class="day-dot ${done ? 'done' : ''} ${isToday ? 'today' : ''}" title="${ds}"></div>`;
  }
  container.innerHTML = html;
  setEl('stat-streak', streakDays.length);
}

// ══════════════════════════════
// INTERVIEW QUESTIONS
// ══════════════════════════════
function renderIQ(questions, containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;
  let html = '';
  questions.forEach((q, i) => {
    html += `<div class="iq-card">
      <div class="iq-q" onclick="toggleIQ(this)">
        <div class="iq-num">${String(i+1).padStart(2,'0')}</div>
        <div style="flex:1">${q.q}</div>
        <span style="color:var(--text3);font-size:12px">▼</span>
      </div>
      <div class="iq-a">${q.a}</div>
    </div>`;
  });
  container.innerHTML = html;
}

function toggleIQ(header) {
  const ans = header.nextElementSibling;
  ans.classList.toggle('open');
}

// ══════════════════════════════
// PAGE NAVIGATION
// ══════════════════════════════
const pageTitles = {
  dashboard: ['Dashboard', 'Your analytics learning command center'],
  plan90: ['30-60-90 Day Plan', 'Structured path from beginner to job-ready'],
  'sql-basics': ['SQL Basics', 'Foundations of querying relational databases'],
  'sql-intermediate': ['SQL Intermediate', 'JOINs, CTEs, subqueries, and more'],
  'sql-advanced': ['SQL Advanced', 'Window functions and query optimization'],
  'py-basics': ['Python Basics', 'Core Python for data work'],
  'py-pandas': ['Pandas & NumPy', 'Data wrangling and manipulation'],
  'py-viz': ['Visualization', 'Charts and dashboards'],
  'py-stats': ['Statistics & ML Basics', 'Statistical analysis and modeling fundamentals'],
  'formula-bible': ['Formula Bible', 'Quick-reference cheat sheets'],
  projects: ['Industry Projects', 'Real-world portfolio projects'],
  interview: ['Interview Prep', 'SQL, Python, and business questions'],
  scenarios: ['Real-Life Scenarios', 'Practical analyst situations'],
  shortcuts: ['Shortcuts & Productivity', 'Work faster with keyboard shortcuts'],
  bestpractices: ['Best Practices', 'How professionals write SQL and Python'],
};

function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const page = document.getElementById(`page-${id}`);
  if (page) page.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.getAttribute('onclick') && n.getAttribute('onclick').includes(`'${id}'`)) n.classList.add('active');
  });
  const info = pageTitles[id] || [id, ''];
  setEl('topbar-title', info[0]);
  setEl('topbar-sub', info[1]);
  window.scrollTo(0, 0);
}

// ══════════════════════════════
// ACCORDION / TABS
// ══════════════════════════════
function toggleAcc(header) {
  const body = header.nextElementSibling;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open');
  const arrow = header.querySelector('span:last-child');
  if (arrow) arrow.textContent = isOpen ? '▼' : '▲';
}

function switchTab(btn, contentId) {
  const tabGroup = btn.closest('.tabs');
  tabGroup.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const allContents = btn.closest('.page, [style]').querySelectorAll('.tab-content');
  allContents.forEach(c => c.classList.remove('active'));
  const target = document.getElementById(`tab-${contentId}`);
  if (target) target.classList.add('active');
}

// ══════════════════════════════
// COPY CODE
// ══════════════════════════════
function copyCode(btn) {
  const block = btn.closest('.code-block');
  const text = block.innerText.replace('Copy\n', '').trim();
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });
}

// ══════════════════════════════
// EXPORT PROGRESS
// ══════════════════════════════
function exportProgress() {
  let report = 'DATA ANALYST ROADMAP — PROGRESS REPORT\n';
  report += `Generated: ${new Date().toLocaleDateString()}\n\n`;
  Object.entries(TOPICS).forEach(([key, topics]) => {
    const p = calcSectionProgress(key);
    report += `${key.toUpperCase()}: ${p.done}/${p.total} (${p.pct}%)\n`;
    topics.forEach((t, i) => {
      report += `  ${checked[`${key}_${i}`] ? '[x]' : '[ ]'} ${t.name}\n`;
    });
    report += '\n';
  });
  const blob = new Blob([report], { type: 'text/plain' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'da_roadmap_progress.txt';
  a.click();
  showToast('Progress exported!');
}

function resetProgress() {
  if (confirm('Reset all progress? This cannot be undone.')) {
    checked = {};
    localStorage.removeItem('da_roadmap_checked');
    Object.keys(TOPICS).forEach(key => {
      const c = document.getElementById(`topics-${key.replace('-','')}`);
      // Re-render all sections
    });
    initAllTopics();
    updateProgress();
    showToast('Progress reset.');
  }
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ══════════════════════════════
// INIT
// ══════════════════════════════
function initAllTopics() {
  renderTopics('sql-basics', 'topics-sql-basics', 'sql-basics');
  renderTopics('sql-int', 'topics-sql-int', 'sql-int');
  renderTopics('sql-adv', 'topics-sql-adv', 'sql-adv');
  renderTopics('py-basics', 'topics-py-basics', 'py-basics');
  renderTopics('py-pandas', 'topics-py-pandas', 'py-pandas');
  renderTopics('py-viz', 'topics-py-viz', 'py-viz');
  renderTopics('py-stats', 'topics-py-stats', 'py-stats');
}

window.addEventListener('DOMContentLoaded', () => {
  initAllTopics();
  renderIQ(IQ.sql, 'iq-sql-container');
  renderIQ(IQ.py, 'iq-py-container');
  renderIQ(IQ.biz, 'iq-biz-container');
  renderIQ(IQ.behav, 'iq-behav-container');
  renderStreak();
  updateProgress();
});
